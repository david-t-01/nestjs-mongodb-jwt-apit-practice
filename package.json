{
  "private": true,
  "author": {
    "name": "David",
    "email": "david-t-01@github.com",
    "url": "https://github.com/david-t-01"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/swagger": "11.2.6",
    "@types/node": "^20.12.7",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "mongoose": "9.3.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.16",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "24.12.0",
    "@types/supertest": "7.2.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": "\\.(spec|test)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
